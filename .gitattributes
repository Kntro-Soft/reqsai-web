# Force LF line endings for all text files (prevents CRLF issues on Windows)
* text=auto eol=lf

# Explicitly LF
*.ts        text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.sh        text eol=lf

# Binary — never diff or convert
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.svg       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.eot       binary
*.pdf       binary
*.zip       binary
bun.lock    binary
